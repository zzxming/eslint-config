{
  "name": "@zzxming/eslint-config",
  "type": "module",
  "version": "0.7.0",
  "packageManager": "pnpm@11.8.0",
  "description": "Eslint config for zzxming",
  "author": "zzxming",
  "license": "MIT",
  "homepage": "https://github.com/zzxming/eslint-config",
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "uvs": "./dist/cli/update-vscode-settings.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm type && tsdown --clean --dts",
    "dev": "npx @eslint/config-inspector --config eslint.config.js",
    "build:inspector": "pnpm build && npx @eslint/config-inspector build --base /eslint-config",
    "test": "vitest",
    "lint": "eslint",
    "prepare": "simple-git-hooks",
    "type": "tsx ./scripts/typegen.ts"
  },
  "peerDependencies": {
    "@prettier/plugin-xml": "^3.4.1",
    "@unocss/eslint-plugin": "^66.0.0",
    "eslint": "^9.10.0 || ^10.0.0"
  },
  "peerDependenciesMeta": {
    "@prettier/plugin-xml": {
      "optional": true
    },
    "@unocss/eslint-plugin": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "catalog:prod",
    "@eslint/markdown": "catalog:prod",
    "@stylistic/eslint-plugin": "catalog:prod",
    "@typescript-eslint/eslint-plugin": "catalog:prod",
    "@typescript-eslint/parser": "catalog:prod",
    "@vitest/eslint-plugin": "catalog:prod",
    "consola": "catalog:prod",
    "eslint-config-flat-gitignore": "catalog:prod",
    "eslint-merge-processors": "catalog:prod",
    "eslint-plugin-antfu": "catalog:prod",
    "eslint-plugin-de-morgan": "catalog:prod",
    "eslint-plugin-format": "catalog:prod",
    "eslint-plugin-import-x": "catalog:prod",
    "eslint-plugin-jsdoc": "catalog:prod",
    "eslint-plugin-jsonc": "catalog:prod",
    "eslint-plugin-n": "catalog:prod",
    "eslint-plugin-perfectionist": "catalog:prod",
    "eslint-plugin-pnpm": "catalog:prod",
    "eslint-plugin-tailwindcss": "catalog:prod",
    "eslint-plugin-unicorn": "catalog:prod",
    "eslint-plugin-unused-imports": "catalog:prod",
    "eslint-plugin-vue": "catalog:prod",
    "eslint-plugin-yml": "catalog:prod",
    "eslint-processor-vue-blocks": "catalog:prod",
    "jsonc-eslint-parser": "catalog:prod",
    "prompts": "catalog:prod",
    "vue-eslint-parser": "catalog:prod",
    "yaml-eslint-parser": "catalog:prod"
  },
  "devDependencies": {
    "@eslint/config-inspector": "catalog:dev",
    "@prettier/plugin-xml": "catalog:peer",
    "@types/eslint-plugin-tailwindcss": "catalog:dev",
    "@types/node": "catalog:dev",
    "@types/prompts": "catalog:dev",
    "@unocss/eslint-plugin": "catalog:peer",
    "eslint": "catalog:peer",
    "eslint-plugin-markdown-preferences": "catalog:dev",
    "eslint-typegen": "catalog:dev",
    "execa": "catalog:dev",
    "find-up-simple": "catalog:inline",
    "globals": "catalog:dev",
    "lint-staged": "catalog:dev",
    "local-pkg": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "tinyglobby": "catalog:dev",
    "tsdown": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "publishConfig": {
    "access": "public"
  }
}
