{
  "name": "@zzxming/eslint-config",
  "type": "module",
  "version": "0.6.3",
  "packageManager": "pnpm@10.33.2",
  "description": "Eslint config for zzxming",
  "author": "zzxming",
  "license": "MIT",
  "homepage": "https://github.com/zzxming/eslint-config",
  "keywords": [
    "eslint-config"
  ],
  "exports": {
    ".": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "uvs": "./dist/cli/update-vscode-settings.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm type && tsdown --clean --dts",
    "dev": "npx @eslint/config-inspector --config eslint.config.js",
    "build:inspector": "pnpm build && npx @eslint/config-inspector build --base /eslint-config",
    "test": "vitest",
    "lint": "eslint",
    "prepare": "simple-git-hooks",
    "type": "tsx ./scripts/typegen.ts"
  },
  "peerDependencies": {
    "@prettier/plugin-xml": "^3.4.1",
    "@unocss/eslint-plugin": "^66.0.0",
    "eslint": "^9.10.0 || ^10.0.0",
    "eslint-plugin-react-refresh": "^0.4.20"
  },
  "peerDependenciesMeta": {
    "@prettier/plugin-xml": {
      "optional": true
    },
    "@unocss/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-react-refresh": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/install-pkg": "^1.1.0",
    "@eslint-react/eslint-plugin": "^2.11.2",
    "@eslint/markdown": "^8.0.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@unocss/eslint-plugin": "^66.6.8",
    "@vitest/eslint-plugin": "^1.6.16",
    "consola": "^3.4.2",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-antfu": "^3.2.2",
    "eslint-plugin-de-morgan": "^2.1.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.0",
    "eslint-plugin-yml": "^3.3.2",
    "eslint-processor-vue-blocks": "^2.0.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prompts": "^2.4.2",
    "vue-eslint-parser": "^10.4.0",
    "yaml-eslint-parser": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^2.0.0",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.2.1",
    "eslint-plugin-markdown-preferences": "^0.41.1",
    "eslint-typegen": "^2.3.1",
    "execa": "^9.6.1",
    "globals": "^17.5.0",
    "lint-staged": "^16.4.0",
    "local-pkg": "^1.1.2",
    "simple-git-hooks": "^2.13.1",
    "tinyglobby": "^0.2.16",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "publishConfig": {
    "access": "public"
  }
}
